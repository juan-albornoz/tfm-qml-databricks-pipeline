*.pkl
*.onnx
*.npy

# Figuras generadas — se regeneran desde los notebooks
# *.png — ver excepcion abajo
*.jpg
*.jpeg

# Python
__pycache__/
*.py[cod]
*.egg-info/
.env
venv/
.venv/

# Jupyter checkpoints
.ipynb_checkpoints/

# IDEs
.vscode/
.idea/

# Databricks
.databricks/

# OS
.DS_Store
Thumbs.db

# Figuras del proyecto — incluir carpeta figures/
